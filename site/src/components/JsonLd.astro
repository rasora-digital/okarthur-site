---
import { person } from '../lib/schema';

interface Props {
	/** Page-specific schemas joined to the site-wide Person. */
	extra?: Record<string, unknown>[];
}

const { extra = [] } = Astro.props;

const graph = {
	'@context': 'https://schema.org',
	'@graph': [person, ...extra],
};

/** A literal </script> inside the JSON would close the tag early. */
const json = JSON.stringify(graph).replace(/</g, '\\u003c');
---

<script type="application/ld+json" is:inline set:html={json} />
