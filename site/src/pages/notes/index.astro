---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes', ({ data }) => !data.draft);
const notes = allNotes.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});

const isoDate = (date: Date) => date.toISOString().slice(0, 10);
---

<Base
	title="Notes"
	description="Working notes on digital, data and AI in infrastructure, from digital twins to whole-life asset decisions on live capital delivery."
>
	<div class="page-head">
		<h1 class="page-title">Notes</h1>
		<p class="lede">
			Short, working notes on digital, data and AI in infrastructure. What
			I'm thinking through on live capital delivery, digital twins and
			whole-life asset decisions, written for the people who have to make it
			work.
		</p>
	</div>

	{
		notes.length === 0 ? (
			<p class="contents-empty">No notes published yet.</p>
		) : (
			<ul class="contents">
				{notes.map((note) => (
					<li class="reveal">
						<div class="entry">
							<div class="entry-meta">
								<time class="meta" datetime={isoDate(note.data.pubDate)}>
									{dateFormatter.format(note.data.pubDate)}
								</time>
							</div>
							<div class="entry-body">
								<h2 class="contents-title">
									<a href={`/notes/${note.id}`}>{note.data.title}</a>
								</h2>
								<p class="contents-summary">{note.data.description}</p>
							</div>
						</div>
					</li>
				))}
			</ul>
		)
	}

	<div class="elsewhere reveal">
		<h2 class="elsewhere-title">Published elsewhere</h2>
		<p>Selected writing and talks for other publications and institutions.</p>
	</div>
</Base>
