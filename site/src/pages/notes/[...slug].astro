---
import Base from '../../layouts/Base.astro';
import { PERSON_ID } from '../../lib/schema';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const notes = await getCollection('notes', ({ data }) => !data.draft);
	return notes.map((note) => ({
		params: { slug: note.id },
		props: { note },
	}));
}

const { note } = Astro.props;
const { Content } = await render(note);

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});

const isoDate = note.data.pubDate.toISOString().slice(0, 10);

const article = {
	'@type': 'Article',
	headline: note.data.title,
	description: note.data.description,
	datePublished: isoDate,
	author: { '@id': PERSON_ID },
	mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
---

<Base
	title={note.data.title}
	description={note.data.description}
	ogType="article"
	schema={[article]}
>
	<article>
		<header class="note-header">
			<div class="entry">
				<div class="entry-meta">
					<time class="meta" datetime={isoDate}>
						{dateFormatter.format(note.data.pubDate)}
					</time>
				</div>
				<div class="entry-body">
					<h1 class="note-title">{note.data.title}</h1>
				</div>
			</div>
		</header>

		<div class="prose note-body">
			<Content />
		</div>
	</article>
</Base>
