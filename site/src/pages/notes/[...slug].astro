---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const notes = await getCollection('notes');
	return notes.map((note) => ({
		params: { slug: note.id },
		props: { note },
	}));
}

const { note } = Astro.props;
const { Content } = await render(note);

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});

const isoDate = note.data.pubDate.toISOString().slice(0, 10);
---

<Base title={note.data.title}>
	<article>
		<header class="note-header">
			<div class="entry">
				<div class="entry-meta">
					<time class="meta" datetime={isoDate}>
						{dateFormatter.format(note.data.pubDate)}
					</time>
				</div>
				<div class="entry-body">
					<h1 class="note-title">{note.data.title}</h1>
				</div>
			</div>
		</header>

		<div class="prose note-body">
			<Content />
		</div>
	</article>
</Base>
