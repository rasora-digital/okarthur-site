{
  "$schema": "https://json-schema.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(.env.local)",
      "Read(**/.env.local)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/rclone/**)",
      "Read(~/.claude/.credentials.json)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)"
    ],
    "allow": [
      "Bash(make check)",
      "Bash(make lint)",
      "Bash(make fmt)",
      "Bash(pre-commit run*)"
    ]
  }
}
